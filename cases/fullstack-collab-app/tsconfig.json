{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2023",
    "types": ["vite/client"]
  },
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/test"],
  "include": ["src"]
}
