{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dragonboat.dev/schemas/v0/workflow-plan.schema.json",
  "title": "DragonBoat Workflow Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "goal",
    "workspace_root",
    "created_at",
    "human_approval_required",
    "limits",
    "phases",
    "quality_patterns",
    "approval_gates"
  ],
  "properties": {
    "schema_version": {
      "const": "dragonboat.workflow_plan.v0"
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^workflow_[A-Za-z0-9_-]+$"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "workspace_root": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "human_approval_required": {
      "type": "boolean"
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_concurrency",
        "max_total_agents"
      ],
      "properties": {
        "max_concurrency": {
          "type": "integer",
          "minimum": 1
        },
        "max_total_agents": {
          "type": "integer",
          "minimum": 1
        },
        "token_cap": {
          "type": "integer",
          "minimum": 1
        },
        "cost_cap_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/phase"
      }
    },
    "quality_patterns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/quality_pattern"
      }
    },
    "approval_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "title",
        "max_agents",
        "routes",
        "inputs",
        "outputs",
        "stop_condition",
        "quality_patterns",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "discover",
            "shard",
            "fanout",
            "cross_check",
            "synthesize",
            "verify"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "max_agents": {
          "type": "integer",
          "minimum": 1
        },
        "routes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stop_condition": {
          "type": "string",
          "minLength": 1
        },
        "quality_patterns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/quality_pattern"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "started",
            "completed",
            "blocked",
            "skipped"
          ]
        }
      }
    },
    "quality_pattern": {
      "type": "string",
      "enum": [
        "map_reduce",
        "refuter",
        "claim_vote",
        "independent_verify",
        "fix_loop"
      ]
    }
  }
}
