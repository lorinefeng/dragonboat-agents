{
  "name": "@dragonboat/demo-web",
  "version": "0.0.0-private",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json --noEmit && vite build"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@remotion/cli": "^4.0.462",
    "@types/ws": "^8.18.1",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "hono": "^4.10.6",
    "lucide-react": "^0.554.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remotion": "^4.0.462",
    "ws": "^8.20.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "jsdom": "^27.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.13"
  }
}
